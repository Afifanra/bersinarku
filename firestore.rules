rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - name: string (required) - Full name
    //   - email: string (required) - Email address
    //   - role: string (required) - User role ('public', 'admin', 'leader', 'superadmin')
    //   - phone: string (optional) - WhatsApp/Phone number
    //   - nik: string (optional) - National ID number
    //   - address: string (optional) - Physical address
    //   - createdAt: timestamp (required)
    //
    // Collection: services
    // Document ID: {serviceId}
    // Fields:
    //   - name: string (required)
    //   - description: string (required)
    //   - fields: list (required)
    //   - isActive: boolean (required)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //
    // Collection: applications
    // Document ID: {applicationId}
    // Fields:
    //   - userId: string (required)
    //   - userName: string (required)
    //   - userPhone: string (optional)
    //   - serviceId: string (required)
    //   - serviceName: string (required)
    //   - status: string (required) - 'pending', 'verified', 'processing', 'waiting_tte', 'completed', 'rejected'
    //   - data: map (required)
    //   - history: list (optional)
    //   - resultDocumentUrl: string (optional)
    //   - rejectionReason: string (optional)
    //   - leaderNotes: string (optional)
    //   - registrationNumber: string (required)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //
    // Collection: audit_logs
    // Document ID: {logId}
    // Fields:
    //   - userId: string (required)
    //   - userName: string (required)
    //   - action: string (required)
    //   - details: string (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (getUserData().role == 'admin' || getUserData().role == 'superadmin' || 
        request.auth.token.email == "afifsmikal@gmail.com" ||
        request.auth.token.email == "hdikemenagjember@gmail.com");
    }
    
    function isLeader() {
      return isAuthenticated() && 
        (getUserData().role == 'leader' || getUserData().role == 'superadmin' || 
        request.auth.token.email == "afifsmikal@gmail.com" ||
        request.auth.token.email == "hdikemenagjember@gmail.com");
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && 
        (getUserData().role == 'superadmin' || 
        request.auth.token.email == "afifsmikal@gmail.com" ||
        request.auth.token.email == "hdikemenagjember@gmail.com");
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    // Domain Validators
    function isValidUser(data) {
      return hasRequiredFields(['uid', 'name', 'email', 'role', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.role in ['public', 'admin', 'leader', 'superadmin'] &&
             data.createdAt is timestamp &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 20)) &&
             (!('nik' in data) || (data.nik is string && data.nik.size() <= 20)) &&
             (!('address' in data) || (data.address is string && data.address.size() <= 500));
    }
    
    function isValidService(data) {
      return hasRequiredFields(['name', 'description', 'fields', 'isActive', 'createdAt', 'updatedAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.description is string && data.description.size() <= 1000 &&
             data.fields is list && data.fields.size() <= 50 &&
             data.isActive is bool &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }
    
    function isValidApplication(data) {
      return hasRequiredFields(['userId', 'userName', 'serviceId', 'serviceName', 'status', 'data', 'registrationNumber', 'createdAt', 'updatedAt']) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.userName is string && data.userName.size() > 0 && data.userName.size() < 100 &&
             data.serviceId is string && data.serviceId.size() > 0 && data.serviceId.size() < 100 &&
             data.serviceName is string && data.serviceName.size() > 0 && data.serviceName.size() < 100 &&
             data.status in ['pending', 'verified', 'processing', 'waiting_tte', 'completed', 'rejected'] &&
             data.data is map &&
             data.registrationNumber is string && data.registrationNumber.size() > 0 && data.registrationNumber.size() < 50 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp &&
             (!('userEmail' in data) || (data.userEmail is string && data.userEmail.size() <= 100)) &&
             (!('userPhone' in data) || (data.userPhone is string && data.userPhone.size() <= 20)) &&
             (!('userNik' in data) || (data.userNik is string && data.userNik.size() <= 20)) &&
             (!('history' in data) || (data.history is list && data.history.size() <= 100)) &&
             (!('resultDocumentUrl' in data) || (data.resultDocumentUrl is string && data.resultDocumentUrl.size() <= 500)) &&
             (!('rejectionReason' in data) || (data.rejectionReason is string && data.rejectionReason.size() <= 500)) &&
             (!('leaderNotes' in data) || (data.leaderNotes is string && data.leaderNotes.size() <= 500));
    }
    
    function isValidAuditLog(data) {
      return hasRequiredFields(['userId', 'userName', 'action', 'details', 'createdAt']) &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.userName is string && data.userName.size() > 0 && data.userName.size() < 100 &&
             data.action is string && data.action.size() > 0 && data.action.size() < 100 &&
             data.details is string && data.details.size() <= 1000 &&
             data.createdAt is timestamp;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isLeader();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && uidUnchanged() && 
                    ((isOwner(userId) && request.resource.data.role == 'public') || isSuperAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && uidNotModified() && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    match /services/{serviceId} {
      allow read: if true; // Publicly readable to show available services
      allow create, update, delete: if isSuperAdmin() && (request.method == 'delete' || isValidService(request.resource.data));
    }

    match /applications/{applicationId} {
      allow read: if (isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin() || isLeader())) || 
                  (request.query.limit == 1); // Allow public tracking (limited to 1 result)
      allow create: if isAuthenticated() && isValidApplication(request.resource.data) && 
                    request.resource.data.status == 'pending' && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isValidApplication(request.resource.data) && 
                    request.resource.data.userId == resource.data.userId && // Immutable userId
                    ((request.auth.uid == resource.data.userId && request.resource.data.status == resource.data.status) || isAdmin() || isLeader());
      allow delete: if isSuperAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin() || isLeader();
      allow create: if isAuthenticated() && isValidAuditLog(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; // Immutable logs
    }
  }
}
